{
  "manifest_version": 3,
  "name": "VIPTHINK 讲次配置工具 By 海瀚",
  "version": "1.0.0",
  "description": "独立测试版。配合本地助手，批量配置讲次。",
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "https://jy.vipthink.cn/*",
    "https://aic-gw.vipthink.cn/*",
    "https://cc-vipthink-pub.oss-accelerate.aliyuncs.com/*",
    "http://127.0.0.1:8765/*",
    "http://127.0.0.1:8767/*",
    "http://127.0.0.1:8768/*",
    "http://127.0.0.1:8769/*"
  ],
  "background": {
    "service_worker": "chapter_config.js"
  },
  "action": {
    "default_title": "讲次配置工具 By 海瀚",
    "default_popup": "chapter_config_popup.html"
  }
}
